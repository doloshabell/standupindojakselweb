---
const navLinks = [
  { href: '/',       labelId: 'Tentang Komunitas', labelEn: 'About Community', key: 'nav.home' },
  { href: '/talent', labelId: 'Talent',            labelEn: 'Talent',          key: 'nav.talent' },
  { href: '/event',  labelId: 'Event',             labelEn: 'Event',           key: 'nav.event' },
  { href: '/news',   labelId: 'News',              labelEn: 'News',            key: 'nav.news' },
];

const currentPath = Astro.url.pathname;
---

<!-- Utility Bar -->
<div class="bg-maroon text-white w-full">
  <div class="max-w-[1280px] mx-auto px-4 md:px-8 flex items-center justify-between h-9">
    <p class="kicker text-white/80 hidden md:block" data-t="nav.openMic">
      OPEN MIC SETIAP SABTU — 20:00 — MOVING SPACE, KEMANG
    </p>
    <p class="kicker text-white/80 md:hidden" data-t="nav.openMic">
      OPEN MIC SETIAP SABTU — 20:00
    </p>
    <a
      href="https://www.instagram.com/standupindo_jaksel"
      target="_blank"
      rel="noopener noreferrer"
      class="text-white/60 hover:text-white transition-colors duration-120"
      aria-label="Instagram Standupindo Jaksel"
    >
      <svg width="14" height="14" viewBox="0 0 24 24" fill="currentColor">
        <path d="M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zm0-2.163c-3.259 0-3.667.014-4.947.072-4.358.2-6.78 2.618-6.98 6.98-.059 1.281-.073 1.689-.073 4.948 0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98 1.281.058 1.689.072 4.948.072 3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98-1.281-.059-1.69-.073-4.949-.073zm0 5.838c-3.403 0-6.162 2.759-6.162 6.162s2.759 6.163 6.162 6.163 6.162-2.759 6.162-6.163c0-3.403-2.759-6.162-6.162-6.162zm0 10.162c-2.209 0-4-1.79-4-4 0-2.209 1.791-4 4-4s4 1.791 4 4c0 2.21-1.791 4-4 4zm6.406-11.845c-.796 0-1.441.645-1.441 1.44s.645 1.44 1.441 1.44c.795 0 1.439-.645 1.439-1.44s-.644-1.44-1.439-1.44z"/>
      </svg>
    </a>
  </div>
</div>

<!-- Main Nav -->
<header class="bg-canvas border-b border-hairline sticky top-0 z-50">
  <div class="max-w-[1280px] mx-auto px-4 md:px-8 flex items-center justify-between h-16">

    <!-- Logo -->
    <a href="/" class="flex-shrink-0">
      <img
        src="/logojaksel.png"
        alt="Standupindo Jakarta Selatan"
        class="h-9 w-auto object-contain"
      />
    </a>

    <!-- Desktop Nav -->
    <nav class="hidden md:flex items-center gap-8">
      {navLinks.map(link => (
        <a
          href={link.href}
          class={`font-ui text-sm font-medium transition-colors duration-120
            ${currentPath === link.href || (link.href !== '/' && currentPath.startsWith(link.href))
              ? 'text-accent'
              : 'text-ink hover:text-accent'
            }`}
          data-t={link.key}
        >
          {link.labelId}
        </a>
      ))}
    </nav>

    <!-- Lang Toggle + Mobile Hamburger -->
    <div class="flex items-center gap-3">
      <div class="flex items-center gap-1">
        <button class="lang-btn active" data-lang="id">ID</button>
        <button class="lang-btn" data-lang="en">EN</button>
      </div>

      <!-- Hamburger (mobile) -->
      <button
        id="hamburger"
        class="md:hidden flex flex-col gap-1.5 p-2 w-10 h-10 items-center justify-center"
        aria-label="Toggle menu"
      >
        <span class="block w-5 h-0.5 bg-ink transition-all" id="ham-1"></span>
        <span class="block w-5 h-0.5 bg-ink transition-all" id="ham-2"></span>
        <span class="block w-5 h-0.5 bg-ink transition-all" id="ham-3"></span>
      </button>
    </div>
  </div>

  <!-- Mobile Drawer -->
  <div id="mobile-nav" class="hidden md:hidden bg-canvas border-t border-hairline">
    <nav class="max-w-[1280px] mx-auto px-4 py-2 flex flex-col">
      {navLinks.map(link => (
        <a
          href={link.href}
          class="font-ui text-sm font-medium py-4 border-b border-hairline text-ink hover:text-accent transition-colors"
          data-t={link.key}
        >
          {link.labelId}
        </a>
      ))}
    </nav>
  </div>
</header>

<script>
  const hamburger = document.getElementById('hamburger');
  const mobileNav = document.getElementById('mobile-nav');

  hamburger?.addEventListener('click', () => {
    const isOpen = !mobileNav?.classList.contains('hidden');
    mobileNav?.classList.toggle('hidden', isOpen);
  });
</script>
