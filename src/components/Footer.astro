---
const navLinks = [
  { href: '/',       label: 'Tentang Komunitas', key: 'nav.home' },
  { href: '/talent', label: 'Talent',            key: 'nav.talent' },
  { href: '/event',  label: 'Event',             key: 'nav.event' },
  { href: '/news',   label: 'News',              key: 'nav.news' },
];
---

<footer class="bg-maroon text-white mt-0">
  <div class="max-w-[1280px] mx-auto px-4 md:px-8 py-14">
    <div class="grid grid-cols-1 md:grid-cols-4 gap-10 pb-10 border-b border-white/10">

      <!-- Brand -->
      <div class="md:col-span-1">
        <img
          src="/logojaksel.png"
          alt="Standupindo Jakarta Selatan"
          class="h-10 w-auto object-contain mb-5 brightness-0 invert"
        />
        <p class="font-body text-sm text-white/50 leading-relaxed" data-t="footer.tagline">
          Komunitas Stand-Up Comedy Jakarta Selatan
        </p>
      </div>

      <!-- Navigation -->
      <div>
        <p class="section-label text-white/40 mb-5" data-t="footer.navTitle">NAVIGASI</p>
        <nav class="flex flex-col gap-3">
          {navLinks.map(link => (
            <a
              href={link.href}
              class="font-ui text-sm text-white/60 hover:text-white transition-colors duration-120"
              data-t={link.key}
            >
              {link.label}
            </a>
          ))}
        </nav>
      </div>

      <!-- Social -->
      <div>
        <p class="section-label text-white/40 mb-5" data-t="footer.socialTitle">IKUTI KAMI</p>
        <div class="flex flex-col gap-3">
          <a
            href="https://www.instagram.com/standupindo_jaksel"
            target="_blank"
            rel="noopener noreferrer"
            class="font-ui text-sm text-white/60 hover:text-white transition-colors flex items-center gap-2"
          >
            <svg width="14" height="14" viewBox="0 0 24 24" fill="currentColor">
              <path d="M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zm0-2.163c-3.259 0-3.667.014-4.947.072-4.358.2-6.78 2.618-6.98 6.98-.059 1.281-.073 1.689-.073 4.948 0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98 1.281.058 1.689.072 4.948.072 3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98-1.281-.059-1.69-.073-4.949-.073zm0 5.838c-3.403 0-6.162 2.759-6.162 6.162s2.759 6.163 6.162 6.163 6.162-2.759 6.162-6.163c0-3.403-2.759-6.162-6.162-6.162zm0 10.162c-2.209 0-4-1.79-4-4 0-2.209 1.791-4 4-4s4 1.791 4 4c0 2.21-1.791 4-4 4zm6.406-11.845c-.796 0-1.441.645-1.441 1.44s.645 1.44 1.441 1.44c.795 0 1.439-.645 1.439-1.44s-.644-1.44-1.439-1.44z"/>
            </svg>
            @standupindo_jaksel
          </a>
        </div>
      </div>

      <!-- Contact -->
      <div>
        <p class="section-label text-white/40 mb-5" data-t="footer.contactTitle">KONTAK</p>
        <div class="flex flex-col gap-2 font-ui text-sm text-white/60">
          <p>Oky Rilokapanji</p>
          <p>085780674188</p>
          <p class="mt-3 leading-relaxed" data-t="footer.openMicInfo">
            Open Mic setiap Sabtu, 20:00<br/>Moving Space, Kemang
          </p>
        </div>
      </div>
    </div>

    <!-- Copyright -->
    <p class="mt-8 font-ui text-xs text-white/30 text-center" data-t="footer.copyright">
      © 2026 Standupindo Jakarta Selatan. All rights reserved.
    </p>
  </div>
</footer>
