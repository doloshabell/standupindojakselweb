---
import '../styles/global.css';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import { translations } from '../i18n/translations';

interface Props {
  title: string;
  description?: string;
}

const { title, description = 'Komunitas Stand-Up Comedy Jakarta Selatan' } = Astro.props;
const t = translations;
---

<!doctype html>
<html lang="id">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title} | Standupindo Jakarta Selatan</title>
    <meta name="description" content={description} />
    <link rel="icon" href="/logojaksel.png" type="image/png" />
  </head>
  <body>
    <Header />
    <main>
      <slot />
    </main>
    <Footer />

    <script define:vars={{ t }}>
      const TRANSLATIONS = t;

      function setLang(lang) {
        document.querySelectorAll('[data-t]').forEach(el => {
          const key = el.getAttribute('data-t');
          const val = key.split('.').reduce((obj, k) => obj?.[k], TRANSLATIONS[lang]);
          if (val !== undefined) el.textContent = val;
        });

        document.querySelectorAll('[data-t-placeholder]').forEach(el => {
          const key = el.getAttribute('data-t-placeholder');
          const val = key.split('.').reduce((obj, k) => obj?.[k], TRANSLATIONS[lang]);
          if (val !== undefined) el.placeholder = val;
        });

        document.querySelectorAll('[data-t-href]').forEach(el => {
          const key = el.getAttribute('data-t-href');
          const val = key.split('.').reduce((obj, k) => obj?.[k], TRANSLATIONS[lang]);
          if (val !== undefined) el.href = val;
        });

        // Bilingual JSON content via data-id / data-en attributes
        document.querySelectorAll('[data-id][data-en]').forEach(el => {
          const val = lang === 'en' ? el.getAttribute('data-en') : el.getAttribute('data-id');
          if (val !== null) el.textContent = val;
        });

        // Multi-paragraph bilingual content
        document.querySelectorAll('[data-paragraphs-id]').forEach(el => {
          const content = lang === 'en'
            ? el.getAttribute('data-paragraphs-en')
            : el.getAttribute('data-paragraphs-id');
          if (content) {
            el.innerHTML = '';
            content.split('\n\n').filter(Boolean).forEach(text => {
              const p = document.createElement('p');
              p.textContent = text;
              el.appendChild(p);
            });
          }
        });

        // Select options with data-t-select
        document.querySelectorAll('[data-t-select]').forEach(el => {
          const key = el.getAttribute('data-t-select');
          const options = key.split('.').reduce((obj, k) => obj?.[k], TRANSLATIONS[lang]);
          if (Array.isArray(options)) {
            const placeholder = el.options[0];
            if (placeholder) {
              const pKey = placeholder.getAttribute('data-t');
              if (pKey) {
                const pVal = pKey.split('.').reduce((obj, k) => obj?.[k], TRANSLATIONS[lang]);
                if (pVal) placeholder.textContent = pVal;
              }
            }
            while (el.options.length > 1) el.remove(1);
            options.forEach(opt => el.add(new Option(opt, opt)));
          }
        });

        localStorage.setItem('lang', lang);
        document.documentElement.lang = lang;

        document.querySelectorAll('.lang-btn').forEach(btn => {
          btn.classList.toggle('active', btn.getAttribute('data-lang') === lang);
        });
      }

      function initLang() {
        const saved = localStorage.getItem('lang') || 'id';
        if (saved !== 'id') setLang(saved);
        document.querySelectorAll('.lang-btn').forEach(btn => {
          btn.classList.toggle('active', btn.getAttribute('data-lang') === saved);
        });
      }

      document.querySelectorAll('.lang-btn').forEach(btn => {
        btn.addEventListener('click', () => setLang(btn.getAttribute('data-lang')));
      });

      document.addEventListener('DOMContentLoaded', initLang);
    </script>
  </body>
</html>
