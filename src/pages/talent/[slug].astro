---
import BaseLayout from '../../layouts/BaseLayout.astro';
import komika from '../../data/komika.json';

export function getStaticPaths() {
  return komika.map(k => ({ params: { slug: k.slug }, props: { komika: k } }));
}

const { komika: k } = Astro.props;
---

<BaseLayout title={k.name} description={k.bio}>

  <div class="max-w-[1280px] mx-auto px-4 md:px-8 py-8">
    <a href="/talent" class="kicker text-caption hover:text-accent transition-colors block mb-8"
       data-t="talent.backLabel">← Kembali ke Talent</a>

    <div class="grid grid-cols-1 md:grid-cols-2 gap-0 border-t border-hairline pt-10">

      <!-- Photo -->
      <div class="border-r-0 md:border-r border-hairline pr-0 md:pr-12 mb-8 md:mb-0">
        <div class="aspect-[16/9] bg-ink/8 flex items-center justify-center">
          <p class="kicker text-caption">FOTO KOMIKA</p>
        </div>
      </div>

      <!-- Info -->
      <div class="pl-0 md:pl-12">
        <p class="kicker text-accent mb-2">{k.kicker}</p>
        <h1 class="font-display font-semibold text-[clamp(2.5rem,6vw,4rem)] leading-none tracking-[-1.5px] text-ink mb-4">
          {k.name}
        </h1>
        <div class="w-10 h-0.5 bg-accent mb-8"></div>

        <p class="section-label text-caption mb-3" data-t="talent.bioLabel">BIO</p>
        <p class="font-body text-base leading-relaxed text-ink mb-10">{k.bio}</p>

        <p class="section-label text-caption mb-4" data-t="talent.socialLabel">MEDIA SOSIAL</p>
        <div class="flex flex-wrap gap-3">
          {k.social.instagram && (
            <a href={k.social.instagram} target="_blank" rel="noopener noreferrer"
               class="btn-primary flex items-center gap-2">
              <svg width="15" height="15" viewBox="0 0 24 24" fill="currentColor">
                <path d="M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zm0-2.163c-3.259 0-3.667.014-4.947.072-4.358.2-6.78 2.618-6.98 6.98-.059 1.281-.073 1.689-.073 4.948 0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98 1.281.058 1.689.072 4.948.072 3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98-1.281-.059-1.69-.073-4.949-.073zm0 5.838c-3.403 0-6.162 2.759-6.162 6.162s2.759 6.163 6.162 6.163 6.162-2.759 6.162-6.163c0-3.403-2.759-6.162-6.162-6.162zm0 10.162c-2.209 0-4-1.79-4-4 0-2.209 1.791-4 4-4s4 1.791 4 4c0 2.21-1.791 4-4 4zm6.406-11.845c-.796 0-1.441.645-1.441 1.44s.645 1.44 1.441 1.44c.795 0 1.439-.645 1.439-1.44s-.644-1.44-1.439-1.44z"/>
              </svg>
              Instagram
            </a>
          )}
          {k.social.tiktok && (
            <a href={k.social.tiktok} target="_blank" rel="noopener noreferrer"
               class="btn-ghost flex items-center gap-2">
              TikTok
            </a>
          )}
          {k.social.youtube && (
            <a href={k.social.youtube} target="_blank" rel="noopener noreferrer"
               class="btn-ghost flex items-center gap-2">
              YouTube
            </a>
          )}
        </div>
      </div>
    </div>
  </div>

</BaseLayout>
